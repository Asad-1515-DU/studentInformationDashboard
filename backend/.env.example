# Backend Environment Configuration

# Server Settings
PORT=5000
NODE_ENV=development

# Database Configuration
# For PostgreSQL on Render, use: postgresql://user:password@host/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/student_db

# CORS Configuration
# For local development: http://localhost:3000
# For Vercel production: https://your-vercel-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# API Configuration (Optional - has defaults)
API_PREFIX=/api
API_VERSION=v1

# Logging Configuration (Optional - defaults to 'debug')
LOG_LEVEL=debug
