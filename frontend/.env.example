# Vite Frontend Environment Variables
# Note: All variables must be prefixed with VITE_ to be accessible in the application

# API Configuration
# For local development: http://localhost:5000/api/v1
# For Render production: https://your-render-app.onrender.com/api/v1
VITE_REACT_APP_API_URL=http://localhost:5000/api/v1

# Environment
VITE_REACT_APP_ENV=development

# Optional: Logging level
VITE_REACT_APP_LOG_LEVEL=debug

# Optional: Feature flags
VITE_REACT_APP_ENABLE_ANALYTICS=false
